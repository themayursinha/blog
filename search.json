---
layout: null
permalink: /search.json
---
{%- assign first = true -%}
[
{%- for post in site.posts -%}
{%- if first %}{% else %},{% endif -%}
{
  "id": {{ post.url | jsonify }},
  "type": "post",
  "title": {{ post.title | jsonify }},
  "subtitle": {{ post.subtitle | default: '' | jsonify }},
  "url": {{ post.url | absolute_url | jsonify }},
  "date": {{ post.date | date: '%Y-%m-%d' | jsonify }},
  "excerpt": {{ post.content | strip_html | strip_newlines | replace: '\t', ' ' | truncate: 600 | jsonify }},
  "tags": {{ post.tags | default: empty | jsonify }}
}
{%- assign first = false -%}
{%- endfor -%}
{%- for p in site.pages -%}
{%- assign skip = false -%}
{%- if p.url == '/404.html' or p.url == '/feed.xml' or p.url == '/atom.xml' or p.url == '/rss.xml' or p.url == '/robots.txt' or p.url == '/search.json' or p.url == '/search/' -%}
{%- assign skip = true -%}
{%- elsif p.path contains '/_layouts/' or p.path contains '/_includes/' -%}
{%- assign skip = true -%}
{%- elsif p.output == false -%}
{%- assign skip = true -%}
{%- endif -%}
{%- unless skip -%}
{%- if first %}{% else %},{% endif -%}
{
  "id": {{ p.url | jsonify }},
  "type": "page",
  "title": {{ p.title | default: p.name | jsonify }},
  "subtitle": {{ p.subtitle | default: '' | jsonify }},
  "url": {{ p.url | absolute_url | jsonify }},
  "date": "",
  "excerpt": {{ p.content | default: '' | strip_html | strip_newlines | replace: '\t', ' ' | truncate: 600 | jsonify }},
  "tags": []
}
{%- assign first = false -%}
{%- endunless -%}
{%- endfor -%}
{%- for proj in site.data.projects -%}
{%- assign proj_url = '' -%}
{%- if proj.links and proj.links.size > 0 -%}
{%- assign proj_url = proj.links[0].url -%}
{%- endif -%}
{%- if first %}{% else %},{% endif -%}
{
  "id": "project-{{ proj.id }}",
  "type": "project",
  "title": {{ proj.title | jsonify }},
  "subtitle": {{ proj.role | append: ' · ' | append: proj.year | jsonify }},
  "url": {{ proj_url | jsonify }},
  "date": "",
  "excerpt": {{ proj.summary | jsonify }},
  "tags": []
}
{%- assign first = false -%}
{%- endfor -%}
]

